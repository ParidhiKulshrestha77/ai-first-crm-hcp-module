# ------------------------------
# FastAPI / App settings
# ------------------------------

# Groq API key (required for AI-powered processing)
GROQ_API_KEY=

# --- Database ---
# Local default (SQLite). For Neon Postgres, set to the Neon connection string.
# Examples:
#   sqlite:///./hcp_crm.db
#   postgresql+psycopg2://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=sqlite:///./hcp_crm.db

# --- LLM models ---
PRIMARY_MODEL=llama-3.3-70b-versatile
CONTEXT_MODEL=llama-3.3-70b-versatile

# --- CORS ---
# Local dev origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Environment ---
environment=development

